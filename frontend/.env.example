# WalletConnect project ID — enables MetaMask on mobile Chrome/Safari (free at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

VITE_GOOGLE_MAPS_API_KEY=

# Mock property/rental/geocoding repos. MetaMask signing still uses your real wallet.
VITE_USE_MOCKS=true

# Skip on-chain owner/tenant checks for smartlock unlock (signing still runs in MetaMask).
VITE_SMARTLOCK_MOCK_MODE=true

VITE_PROPERTY_NFT_ADDRESS=
VITE_RENTAL_FACTORY_ADDRESS=
VITE_USDC_ADDRESS=
VITE_REVIEW_SYSTEM_ADDRESS=
VITE_TARGET_CHAIN_ID=31337
